# Virtual network for the VM
resource "azurerm_virtual_network" "vnet" {
  name                = "multi-agent-lab-vnet"
  address_space       = ["10.0.0.0/16"]
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
}

# Subnet for the VM
resource "azurerm_subnet" "subnet" {
  name                 = "multi-agent-lab-subnet"
  resource_group_name  = azurerm_resource_group.rg.name
  virtual_network_name = azurerm_virtual_network.vnet.name
  address_prefixes     = ["10.0.1.0/24"]
}

# Network interface
resource "azurerm_network_interface" "nic" {
  name                = "multi-agent-lab-nic"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name

  ip_configuration {
    name                          = "internal"
    subnet_id                     = azurerm_subnet.subnet.id
    private_ip_address_allocation = "Dynamic"
  }
}

# Public IP (optional, Tailscale will handle access)
resource "azurerm_public_ip" "public_ip" {
  name                = "multi-agent-lab-ip"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name
  allocation_method   = "Static"
  sku                 = "Standard"
}

# Attach public IP to NIC
resource "azurerm_network_interface" "nic_with_ip" {
  name                = "multi-agent-lab-nic-ip"
  location            = azurerm_resource_group.rg.location
  resource_group_name = azurerm_resource_group.rg.name

  ip_configuration {
    name                          = "internal"
    subnet_id                     = azurerm_subnet.subnet.id
    private_ip_address_allocation = "Dynamic"
    public_ip_address_id          = azurerm_public_ip.public_ip.id
  }
}

# The VM itself
resource "azurerm_linux_virtual_machine" "vm" {
  name                = "multi-agent-lab-vm"
  resource_group_name = azurerm_resource_group.rg.name
  location            = azurerm_resource_group.rg.location
  size                = "Standard_B2s"
  admin_username      = "ty"

  network_interface_ids = [
    azurerm_network_interface.nic_with_ip.id
  ]

  admin_ssh_key {
    username   = "ty"
    public_key = file("~/.ssh/id_rsa.pub")
  }

  # cloud-init will bootstrap Docker, Tailscale, and your agents
  custom_data = base64encode(file("${path.module}/cloud-init/init.yaml"))

  os_disk {
    caching              = "ReadWrite"
    storage_account_type = "Standard_LRS"
  }

  source_image_reference {
    publisher = "Canonical"
    offer     = "0001-com-ubuntu-server-jammy"
    sku       = "22_04-lts"
    version   = "latest"
  }
}
